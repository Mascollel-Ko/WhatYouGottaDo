    <string name="app_explanation_title">앱 설명</string>
    <string name="app_explanation_hero_title">운동 기록을 분석과 계획으로</string>
    <string name="app_explanation_intro">WhatYouGottaDo는 근력운동과 배드민턴 기록을 바탕으로, 현재 피로와 훈련의 균형을 분석하고 다음 운동 계획을 돕습니다.</string>
    <string name="app_explanation_features_title">이 앱이 분석하는 것</string>

    <string name="app_explanation_feature_fatigue_title">피로를 다섯 가지로 구분합니다</string>
    <string name="app_explanation_feature_fatigue_body">무거운 힘, 전신, 특정 근육, 빠른 동작, 반응성 동작의 피로를 따로 봅니다.</string>
    <string name="app_explanation_feature_muscles_title">피로한 근육을 보여줍니다</string>
    <string name="app_explanation_feature_muscles_body">현재 어떤 근육의 피로가 상대적으로 많이 남아 있는지 확인합니다.</string>
    <string name="app_explanation_feature_tissue_title">연결조직의 부하를 따로 봅니다</string>
    <string name="app_explanation_feature_tissue_body">관절·건·인대 등에 남아 있을 운동 부하의 상대적 추세를 보여줍니다.</string>
    <string name="app_explanation_feature_badminton_title">배드민턴 훈련을 분석합니다</string>
    <string name="app_explanation_feature_badminton_body">경기·레슨·풋워크·기술훈련의 운동량과 훈련 목적을 구분합니다.</string>
    <string name="app_explanation_feature_strength_title">근력운동량을 계산합니다</string>
    <string name="app_explanation_feature_strength_body">중량운동과 풀업·푸시업·플랭크를 각 운동 특성에 맞게 계산합니다.</string>
    <string name="app_explanation_feature_program_title">운동 프로그램 초안을 만듭니다</string>
    <string name="app_explanation_feature_program_body">가능한 요일과 시간, 필수 운동과 제외 운동을 바탕으로 계획을 구성합니다.</string>

    <string name="app_explanation_limitation_title">점수는 진단이 아닙니다</string>
    <string name="app_explanation_limitation_primary">앱의 점수는 부상확률이나 조직 손상량이 아닙니다. 내 기록 안에서 피로와 부하가 어떻게 변하는지 확인하기 위한 상대적 지표입니다.</string>
    <string name="app_explanation_limitation_secondary">통증이나 불안정감 같은 실제 증상을 앱 점수보다 우선하세요.</string>

    <string name="analysis_guide_title">분석 결과 읽는 법</string>
    <string name="analysis_guide_open_description">분석 결과 읽는 법 열기</string>
    <string name="analysis_guide_intro">분석 결과는 절대적인 건강 판정이 아니라, 내 운동 기록에서 피로와 부하의 흐름을 확인하기 위한 정보입니다.</string>
    <string name="analysis_guide_overall_title">전체 피로 상태</string>
    <string name="analysis_guide_overall_body">다섯 가지 피로 축을 종합해 현재 운동 부담의 전반적인 상태를 보여줍니다.</string>
    <string name="analysis_guide_axes_title">다섯 가지 피로 축</string>
    <string name="analysis_guide_axes_body">무거운 힘, 전신, 특정 근육, 빠른 동작, 반응성 동작의 피로를 서로 다른 축으로 확인합니다.</string>
    <string name="analysis_guide_muscles_title">피로한 근육</string>
    <string name="analysis_guide_muscles_body">국소 근육 분석에서는 현재 피로가 많이 남아 있는 근육을 우선해서 보여줍니다.</string>
    <string name="analysis_guide_tissue_title">연결조직 분석</string>
    <string name="analysis_guide_tissue_body">관절·건·인대 등의 부하가 평소 기록과 비교해 어느 위치에 있는지 상대적인 추세로 확인합니다.</string>
    <string name="analysis_guide_distribution_title">훈련 분산</string>
    <string name="analysis_guide_distribution_body">근력운동과 배드민턴 훈련이 특정 부위나 목적에 지나치게 집중되지 않았는지 확인합니다.</string>
    <string name="analysis_guide_high_score_title">점수가 높을 때</string>
    <string name="analysis_guide_high_score_body">최근 기록보다 부담이 많이 쌓였다는 신호로 해석하되, 실제 수행감·통증·불안정감과 함께 판단합니다.</string>
    <string name="analysis_guide_calibration_note">기록이 적은 초기에는 개인 기준이 충분하지 않아 결과가 제한적일 수 있습니다.</string>

    <string name="calculation_principles_open_label">계산 원리와 한계 보기</string>
    <string name="calculation_principles_open_description">계산 원리와 한계 설명 열기</string>
    <string name="calculation_principles_title">계산 원리와 한계</string>
    <string name="calculation_principles_intro">이 앱은 운동 기록을 비교 가능한 형태로 바꾸기 위해 여러 계산 프로토콜을 사용합니다.</string>
    <string name="calculation_principles_research_title">연구와 제품 정책을 함께 사용합니다</string>
    <string name="calculation_principles_research_body">일부 계산은 연구에서 직접 확인된 내용을 사용하고, 일부는 관련 연구와 운동 특성을 바탕으로 실용적으로 정한 제품 정책과 휴리스틱을 사용합니다.</string>
    <string name="calculation_principles_transparency_title">계산 방법과 한계를 공개합니다</string>
    <string name="calculation_principles_transparency_body">현재 적용 중인 계산식, 근거 수준, 구현 상태와 알려진 한계를 공개 프로토콜 문서에서 확인할 수 있습니다.</string>
    <string name="calculation_principles_medical_title">의학적 정확성을 주장하지 않습니다</string>
    <string name="calculation_principles_medical_body">피로 점수와 연결조직 점수는 진단, 부상확률, 조직 손상량, 정확한 회복 완료 시각을 뜻하지 않습니다.</string>
